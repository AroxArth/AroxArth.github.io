---
const jobs = [
  {
    company: "LCT Global",
    role: "AI-Driven Software Architect & Full-Stack Developer",
    period: "Nov 2025 — Presente",
    points: [
      "Diseño y construyo sistemas de negocio dirigiendo agentes de IA con SDD y TDD.",
      "Proyectos: Sisges (salud y pensiones), SisBáscula (pesaje de camiones) y WashClaw (SaaS de autolavados).",
    ],
  },
  {
    company: "CCPL — Colegio de Contadores Públicos de Lima",
    role: "Desarrollador de aplicaciones PHP",
    period: "Mar 2025 — Nov 2025 · 9 meses · Presencial",
    points: [
      "Desarrollo back-end y front-end e implementación de sistemas internos.",
      "Sistema de tickets interno, inventario de artefactos informáticos y control, exportación y consultas de base de datos.",
      "Publicación en la web institucional del CCPL (WordPress).",
    ],
  },
];
---

<section id="experience" class="mx-auto max-w-4xl px-6 py-28">
  <p data-animate class="eyebrow" data-index="03">Experiencia</p>
  <h2 data-animate class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
    Dónde trabajé
  </h2>

  <div class="mt-12 space-y-8">
    {
      jobs.map((job, i) => (
        <div data-zig={i % 2 === 0 ? "left" : "right"} class="glass-card project-card p-7">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="text-xl font-semibold">{job.company}</h3>
            <span class="text-sm text-muted">{job.period}</span>
          </div>
          <p class="mt-1 text-accent">{job.role}</p>
          <ul class="mt-4 space-y-2 text-sm leading-relaxed text-muted">
            {job.points.map((p) => (
              <li class="flex gap-2">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
