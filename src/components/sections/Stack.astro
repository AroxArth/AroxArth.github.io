---
const languages = [
  { name: "TypeScript", icon: "devicon-typescript-plain" },
  { name: "JavaScript", icon: "devicon-javascript-plain" },
  { name: "C#", icon: "devicon-csharp-plain" },
  { name: "SQL Server", icon: "devicon-microsoftsqlserver-plain" },
  { name: "PostgreSQL", icon: "devicon-postgresql-plain" },
];

const technologies = [
  { name: "Next.js", icon: "devicon-nextjs-plain" },
  { name: "React", icon: "devicon-react-original" },
  { name: "Node.js", icon: "devicon-nodejs-plain" },
  { name: ".NET MAUI", icon: "devicon-dotnetcore-plain" },
  { name: "Prisma", icon: "devicon-prisma-original" },
  { name: "Tailwind CSS", icon: "devicon-tailwindcss-plain" },
  { name: "Docker", icon: "devicon-docker-plain" },
  { name: "GitHub", icon: "devicon-github-original" },
  { name: "VS Code", icon: "devicon-vscode-plain" },
  { name: "Astro", icon: "devicon-astro-plain" },
];
---

<section id="stack" class="mx-auto max-w-5xl px-6 py-28">
  <p data-animate class="eyebrow" data-index="02">Stack</p>
  <h2 data-animate class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
    Herramientas que uso
  </h2>

  <div class="mt-12 space-y-10">
    <div>
      <h3 data-animate class="mb-5 text-sm font-medium uppercase tracking-wider text-muted">
        Lenguajes
      </h3>
      <ul data-animate-group class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-5">
        {
          languages.map((l) => (
            <li class="tech-tile glass-card group">
              <i class={`${l.icon} text-5xl transition-colors group-hover:text-accent`} aria-hidden="true" />
              <span class="text-sm font-medium">{l.name}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 data-animate class="mb-5 text-sm font-medium uppercase tracking-wider text-muted">
        Tecnologías
      </h3>
      <ul data-animate-group class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-5">
        {
          technologies.map((t) => (
            <li class="tech-tile glass-card group">
              <i class={`${t.icon} text-5xl transition-colors group-hover:text-accent`} aria-hidden="true" />
              <span class="text-sm font-medium">{t.name}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
