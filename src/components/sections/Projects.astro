---
import { projects } from "../../data/projects";
import ProjectShowcase from "../ProjectShowcase.tsx";
---

<section id="projects" class="relative overflow-hidden py-32">
  {/* Soft glow so the section eases in instead of cutting hard. */}
  <div
    class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-80 opacity-70"
    style="background: radial-gradient(60% 100% at 50% 0%, color-mix(in srgb, var(--accent) 16%, transparent), transparent);"
  >
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <p data-animate class="eyebrow" data-index="04">Proyectos</p>
    <h2 data-animate class="mt-3 text-3xl font-semibold tracking-tight sm:text-5xl">
      Lo que construí
    </h2>
    <p data-animate class="mt-3 max-w-2xl text-muted">
      Sistemas reales en producción para empresas, y proyectos personales de la
      idea al prototipo. Desktop, web, móvil e IA. Tocá una tarjeta para ver todo.
    </p>

    <div class="mt-14">
      <ProjectShowcase client:load projects={projects} />
    </div>
  </div>
</section>
