---
import GlassButton from "../GlassButton.astro";
---

<section id="contact" data-cinema class="relative">
  <div class="cinema-sticky">
    <div class="cinema-stage">
      <div class="cinema-scene" data-scene>
        <p class="eyebrow" data-index="05">Contacto</p>
        <h2 class="text-4xl font-semibold tracking-tight sm:text-6xl">
          Construyamos algo
        </h2>
        <p class="max-w-xl text-lg text-muted">
          ¿Tienes un proyecto o una oportunidad? Escríbeme y conversamos.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <GlassButton href="mailto:aroxayasta@gmail.com">Correo</GlassButton>
          <GlassButton
            href="https://github.com/AroxArth"
            target="_blank"
            rel="noopener noreferrer">GitHub</GlassButton
          >
          <GlassButton href="#">LinkedIn</GlassButton>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="py-12 text-center text-sm text-muted">
  © 2026 Jairo Aron Huamán Ayasta · Hecho con Astro y liquid glass.
</footer>
