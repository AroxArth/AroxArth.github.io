---
// Ambient site-wide backdrop: slowly drifting aurora blobs + fine grain.
// Gives the whole page depth and gives the liquid glass something to refract.
---

<div class="aurora" aria-hidden="true">
  <span class="aurora__blob aurora__blob--1"></span>
  <span class="aurora__blob aurora__blob--2"></span>
  <span class="aurora__blob aurora__blob--3"></span>
  <div class="aurora__grain"></div>
</div>
